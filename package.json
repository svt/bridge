{
  "name": "bridge",
  "version": "1.0.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npm run lint && dotenvx run --quiet -f .env.test -- jest",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "start": "electrobun run",
    "dev": "electrobun dev",
    "dev:watch": "electrobun dev --watch",
    "build:dev": "bun install && electrobun build",
    "build:canary": "electrobun build --env=canary",
    "build:stable": "electrobun build --env=stable",
    "nodemon": "nodemon --trace-warnings --inspect=0.0.0.0 index.js",
    "build": "bun scripts/bun-build.js",
    "build:dev": "bun scripts/bun-build.js --dev",
    "clean": "node ./scripts/clean-build-folder.js",
    "prepare": "husky install",
    "postinstall": "node scripts/install-plugin-dependencies.js"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:svt/bridge.git"
  },
  "keywords": [
    "bridge",
    "television",
    "production",
    "graphics"
  ],
  "author": "Axel Boberg (axel.boberg@svt.se)",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.10.0",
    "fast-equals": "^5.3.3",
    "hotkeys-js": "^4.0.1",
    "jose": "^6.0.13",
    "jszip": "^3.10.1",
    "node-policy-agent": "^1.5.0",
    "obj-router": "^3.0.2",
    "object-path": "^0.11.8",
    "react-colorful": "^5.5.1",
    "semver": "^7.3.5",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.38.4",
    "electrobun": "^1.18.1",
    "eslint": "^8.38.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^15.7.0",
    "eslint-plugin-promise": "^6.1.1",
    "husky": "^7.0.4",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-grid-layout": "^1.3.4"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/build/"
    ]
  }
}
